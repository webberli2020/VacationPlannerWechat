.logo-section {
  padding: 60rpx 0;
  text-align: center;
  background: linear-gradient(180deg, #e6f7ff 0%, #f0f2f5 100%);
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}

.app-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.app-version {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.info-card {
  background: white;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1px solid #f5f5f5;
  font-size: 28rpx;
}

.info-row:last-child { border-bottom: none; }
.label { color: #888; }
.value { color: #333; font-weight: 500; }

.description-section, .history-section {
  background: white;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 6rpx solid var(--primary-color);
  padding-left: 20rpx;
}

.desc-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 15rpx;
}

.bold { color: #333; font-weight: bold; }

.log-item { margin-bottom: 25rpx; }
.log-version { font-size: 24rpx; font-weight: bold; color: #444; margin-bottom: 5rpx; }
.log-content { font-size: 24rpx; color: #888; line-height: 1.5; }

.footer {
  text-align: center;
  font-size: 20rpx;
  color: #ccc;
  padding: 40rpx 0;
  margin-top: 20rpx;
}
