/* 全局配色变量 */
page {
  --weekend-color: #ff4d4f;
  --workday-color: #52c41a;
  --primary-color: #1890ff;
  --range-bg: #e6f7ff;
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

button {
  font-weight: normal;
  font-size: 28rpx;
}
